{
  "name": "@abe/web",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js web application for ABE annotation platform",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --config ./config/eslint.js",
    "lint:fix": "eslint . --config ./config/eslint.js --fix",
    "type-check": "tsc --project ./config/typescript.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@abe/cross_platform": "workspace:*",
    "next": "^14.0.4",
    "next-themes": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint-config-next": "^14.0.4",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.5",
    "jest-environment-jsdom": "^29.7.0",
    "cypress": "^13.6.1",
    "@cypress/react18": "^2.0.1",
    "axe-core": "^4.8.3",
    "cypress-axe": "^1.5.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  }
} 